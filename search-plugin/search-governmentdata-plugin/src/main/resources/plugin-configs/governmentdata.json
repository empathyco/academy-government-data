{
  "params": {
    "endPoints": [
      {
        "id": "search",
        "requestors": [
          {
            "features": {
              "fallback": [
                {
                  "name": "spellcheck",
                  "config": {
                    "collectionType": "CATALOG",
                    "mainCollectionId": "governmentdata",
                    "secondaryCollectionId": "governmentdata",
                    "enablePhraseSuggester": true
                  }
                }
              ],
              "search": [
                {
                  "name": "multiMatchSearch",
                  "config": {
                    "searchableFields": [
                      {
                        "name": "name"
                      },
                      {
                        "name": "description"
                      },
                      {
                        "name":"id"
                      }
                    ]
                  }
                },
                {
                  "name": "sorting",
                  "config": {
                    "defaultOrder": "DESC",
                    "fields": [
                      {
                        "field": "_score",
                        "order": "DESC"
                      }
                    ],
                    "whitelist": [
                      "_score"
                    ]
                  }
                },
                {
                  "name": "filtering",
                  "config": {
                    "fields": [
                      {
                        "name": "facet_brand",
                        "queryParam": "brand",
                        "type": "VALUE"
                      },
                      {
                        "name": "facet_price",
                        "queryParam": "price",
                        "type": "RANGE"
                      },
                      {
                        "name": "facet_categoriesIds",
                        "queryParam": "categoryIds",
                        "type": "VALUE"
                      }
                    ]
                  }
                },
                {
                  "name": "faceting",
                  "config": {
                    "context": "SEARCH",
                    "enabled": true,
                    "mainCollectionId": "governmentdata",
                    "secondaryCollectionId": "governmentdata",
                    "facetableFields": {
                      "rangeFacets": [
                        {
                          "field": "facet_price",
                          "filterField": "price",
                          "ranges": [
                            {
                              "to": 10,
                              "gap": 10
                            },
                            {
                              "from": 10,
                              "to": 40,
                              "gap": 10
                            },
                            {
                              "from": 40,
                              "gap": 10
                            }
                          ]
                        }
                      ],
                      "valueFacets": [
                        {
                          "field": "facet_brand",
                          "filterField": "brand",
                          "size": 100,
                          "minCount": 1
                        }
                      ],
                      "hierarchicalFacets": [
                        {
                          "field": "facet_categories",
                          "filterField": "categoryIds",
                          "size": 100,
                          "minCount": 1
                        }
                      ]
                    },
                    "facets": [
                      "facet_brand",
                      "facet_price",
                      "facet_categories"
                    ]
                  }
                },
                {
                  "name": "pagination",
                  "config": {
                    "rows": 20,
                    "start": 0
                  }
                },
                {
                  "name": "boosting",
                  "config": {
                    "context": "SEARCH",
                    "mainCollectionId": "governmentdata",
                    "secondaryCollectionId": "governmentdata"
                  }
                },
                {
                  "name": "searchHits"
                },
                {
                  "name": "totalHits"
                },
                {
                  "name": "debug"
                }
              ]
            },
            "postprocessors": [
              {
                "name": "explain"
              }
            ],
            "id": "catalog",
            "redisCached": false,
            "redisTTL": 250,
            "mainCollectionId": "governmentdata",
            "type": "default"
          },
          {
            "id": "direct",
            "type": "links",
            "secondaryCollectionId": "governmentdata",
            "config": {
              "linkType": "DIRECT",
              "queryParamFilters": [
                {
                  "queryParam": "lang",
                  "field": "langs"
                },
                {
                  "queryParam": "scope",
                  "field": "filters.scope"
                }
              ]
            }
          },
          {
            "id": "promoted",
            "type": "links",
            "secondaryCollectionId": "governmentdata",
            "config": {
              "linkType": "PROMOTED",
              "queryParamFilters": [
                {
                  "queryParam": "lang",
                  "field": "langs"
                },
                {
                  "queryParam": "scope",
                  "field": "filters.scope"
                }
              ]
            }
          },
          {
            "id": "banner",
            "type": "links",
            "secondaryCollectionId": "governmentdata",
            "config": {
              "linkType": "BANNER",
              "queryParamFilters": [
                {
                  "queryParam": "lang",
                  "field": "langs"
                },
                {
                  "queryParam": "scope",
                  "field": "filters.scope"
                }
              ]
            }
          }
        ],
        "type": "custom"
      },
      {
        "id": "browse",
        "requestors": [
          {
            "features": {
              "search": [
                {
                  "name": "browsingSearch"
                },
                {
                  "name": "sorting",
                  "config": {
                    "whitelist": [
                      "boost_category",
                      "facet_brand"
                    ],
                    "fields": [
                      {
                        "field": "_score",
                        "order": "DESC"
                      },
                      {
                        "field": "facet_brand",
                        "order": "ASC"
                      }
                    ],
                    "defaultOrder": "DESC"
                  }
                },
                {
                  "name": "pagination",
                  "config": {
                    "rows": 20,
                    "start": 0
                  }
                },
                {
                  "name": "boosting",
                  "config": {
                    "context": "BROWSE",
                    "mainCollectionId": "governmentdata",
                    "secondaryCollectionId": "governmentdata"
                  }
                },
                {
                  "name": "searchHits",
                  "config": {
                    "origin": "SOURCE",
                    "returnableFields": [
                      {
                        "field": "name"
                      },
                      {
                        "field": "description"
                      },
                      {
                        "field": "boost_category"
                      },
                      {
                        "field": "facet_brand"
                      },
                      {
                        "field": "facet_price"
                      }
                    ]
                  }
                },
                {
                  "name": "filtering",
                  "config": {
                    "fields": [
                      {
                        "name": "facet_brand",
                        "queryParam": "brand",
                        "type": "VALUE"
                      },
                      {
                        "name": "facet_price",
                        "queryParam": "price",
                        "type": "RANGE"
                      },
                      {
                        "name": "facet_categoriesIds",
                        "queryParam": "categoryIds",
                        "type": "VALUE"
                      }
                    ]
                  }
                },
                {
                  "name": "faceting",
                  "config": {
                    "context": "BROWSE",
                    "enabled": true,
                    "mainCollectionId": "governmentdata",
                    "secondaryCollectionId": "governmentdata",
                    "facetableFields": {
                      "rangeFacets": [
                        {
                          "field": "facet_price",
                          "filterField": "price",
                          "ranges": [
                            {
                              "to": 10,
                              "gap": 10
                            },
                            {
                              "from": 10,
                              "to": 40,
                              "gap": 10
                            },
                            {
                              "from": 40,
                              "gap": 10
                            }
                          ]
                        }
                      ],
                      "valueFacets": [
                        {
                          "field": "facet_brand",
                          "filterField": "brand",
                          "size": 100,
                          "minCount": 1
                        }
                      ],
                      "hierarchicalFacets": [
                        {
                          "field": "facet_categories",
                          "filterField": "categoryIds",
                          "size": 100,
                          "minCount": 1
                        }
                      ]
                    },
                    "facets": [
                      "facet_brand",
                      "facet_price",
                      "facet_categories"
                    ]
                  }
                },
                {
                  "name": "debug"
                }
              ]
            },
            "id": "catalog",
            "redisCached": false,
            "redisTTL": 250,
            "mainCollectionId": "governmentdata",
            "type": "default"
          }
        ],
        "type": "custom"
      },
      {
        "id": "empathize",
        "requestors": [
          {
            "id": "topTrends",
            "mainCollectionId": "governmentdata",
            "secondaryCollectionId": "governmentdata",
            "collectionType": "EMPATHIZE",
            "type": "default",
            "redisCached": true,
            "redisTTL": 250,
            "features": {
              "search": [
                {
                  "name": "empathizeMatchSearch",
                  "config": {
                    "field": "keywords",
                    "queryOperator": "AND",
                    "emptyQueryParamAllowed": true,
                    "excludeExactMatch": false
                  }
                },
                {
                  "name": "filtering",
                  "config": {
                    "fields": [
                      {
                        "name": "extra_lang",
                        "queryParam": "lang",
                        "type": "VALUE"
                      }
                    ]
                  }
                },
                {
                  "name": "sorting",
                  "config": {
                    "defaultOrder": "DESC",
                    "fields": [
                      {
                        "field": "weight",
                        "order": "DESC"
                      }
                    ]
                  }
                },
                {
                  "name": "pagination",
                  "config": {
                    "start": 0,
                    "rows": 10
                  }
                },
                {
                  "name": "grouping",
                  "config": {
                    "enabled": true,
                    "field": "keywords.keyword"
                  }
                },
                {
                  "name": "totalHits",
                  "config": {
                    "disableTracking": true
                  }
                },
                {
                  "name": "searchHits",
                  "config": {
                    "returnableFields": [
                      {
                        "field": "keywords",
                        "mandatory": true
                      }
                    ]
                  }
                },
                {
                  "name": "debug"
                }
              ],
              "fallback": [
                {
                  "name": "spellcheck",
                  "config": {
                    "collectionType": "EMPATHIZE",
                    "enablePhraseSuggester": false,
                    "mainCollectionId": "governmentdata",
                    "secondaryCollectionId": "governmentdata"
                  }
                }
              ]
            },
            "transformers": {
              "document": {
                "name": "fieldRename",
                "config": {
                  "fieldMappings": [
                    {
                      "from": "keywords",
                      "to": "title_raw"
                    }
                  ]
                }
              }
            }
          }
        ],
        "type": "custom"
      },
      {
        "id": "topclicked",
        "type": "custom",
        "requestors": [
          {
            "id": "topclicked",
            "type": "default",
            "redisCached": false,
            "redisTTL": 250,
            "mainCollectionId": "governmentdata",
            "secondaryCollectionId": "governmentdata",
            "features": {
              "search": [
                {
                  "name": "topClickedSearch",
                  "config": {
                    "idFieldName": "id",
                    "redisCached": false,
                    "redisTTL": 250,
                    "filters": [
                      {
                        "queryParam": "lang",
                        "field": "extra.lang"
                      }
                    ]
                  }
                },
                {
                  "name": "pagination",
                  "config": {
                    "start": 0,
                    "rows": 20
                  }
                },
                {
                  "name": "grouping",
                  "config": {
                    "enabled": true,
                    "field": "id"
                  }
                },
                {
                  "name": "searchHits"
                },
                {
                  "name": "totalHits"
                },
                {
                  "name": "debug"
                }
              ]
            }
          }
        ]
      },
      {
        "id": "field-values",
        "type": "custom",
        "requestors": [
          {
            "id": "attributes",
            "type": "default",
            "redisCached": false,
            "redisTTL": 250,
            "mainCollectionId": "governmentdata",
            "features": {
              "search": [
                {
                  "name": "fieldValues",
                  "config": {
                    "allowedFields": [
                      {
                        "fieldName": "categoryIds",
                        "aggregationSize": 1000,
                        "aggregationField": "facet_categories"
                      },
                      {
                        "fieldName": "brand",
                        "aggregationSize": 1000,
                        "aggregationField": "facet_brand"
                      }
                    ]
                  }
                },
                {
                  "name": "debug"
                }
              ]
            }
          }
        ]
      }
    ]
  }
}
